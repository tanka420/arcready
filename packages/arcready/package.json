{
  "name": "arcready",
  "version": "0.2.0",
  "description": "Arc-specific CI quality gate and integration validator for wallets, bridges, App Kit integrations, and dApps.",
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tanka420/arcready.git",
    "directory": "packages/arcready"
  },
  "homepage": "https://github.com/tanka420/arcready#readme",
  "bugs": {
    "url": "https://github.com/tanka420/arcready/issues"
  },
  "keywords": [
    "arc",
    "circle",
    "web3",
    "evm",
    "ci",
    "quality-gate",
    "developer-tools",
    "validation",
    "wallet",
    "bridge",
    "app-kit",
    "typescript",
    "github-actions"
  ],
  "bin": {
    "arcready": "dist/bin.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "!dist/**/*.map",
    "README.md",
    "package.json"
  ],
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "arcready": "node ./dist/bin.js",
    "build": "tsup src/index.ts src/bin.ts --format esm --dts --clean --sourcemap",
    "test": "vitest run",
    "dev": "tsx src/bin.ts"
  },
  "devDependencies": {
    "tsx": "^4.19.4"
  }
}
